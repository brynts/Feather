    "You cannot update ‘%@‘ with itself, please use an alternative tool to update it." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst ‘%@‘ nicht mit sich selbst ändern, bitte benutze ein alternatives Tool um es upzudaten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You cannot update ‘%@‘ with itself, please use an alternative tool to update it."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamu tidak bisa melakukan update pada ‘%@’ menggunakan dirinya sendiri. Silakan gunakan tool alternatif untuk memperbaruinya."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
