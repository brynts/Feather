    "This option force converts apps to try to use the new liquid glass redesign iOS 26 introduced, this may not work for all applications due to differing frameworks." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Option erzwingt Apps umzuwandeln um das neue „Liquid Glass“-Redesign zu verwenden welches in iOS 26 eingeführt wurde, dies funktioniert möglicherweise nicht für alle Apps auf Grund von Unterschieden der Frameworks."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This option force converts apps to try to use the new liquid glass redesign iOS 26 introduced, this may not work for all applications due to differing frameworks."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ta opcja wymusza konwersję aplikacji na nowy wygląd liquid glass wprowadzony w iOS 26. Może nie działać ze wszystkimi aplikacjami z powodu różnych frameworków."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tùy chọn này buộc phải chuyển đổi ứng dụng để thử sử dụng giao diện Liquid Glass mới được giới thiệu trong iOS 26. Tùy chọn này có thể không hoạt động với tất cả các ứng dụng do có nhiều khuôn khổ khác nhau."
          }
        }
      }
    },
    "This will delete your imported application after signing, to save on using unneeded space." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies wird deine importierte Datei nach der Signierung löschen, um an unnötigen Speicher zu sparen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will delete your imported application after signing, to save on using unneeded space."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spowoduje to usunięcie zaimportowanej aplikacji po jej podpisaniu, co pozwoli zwolnić miejsce."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thao tác này sẽ xóa ứng dụng đã nhập của bạn sau khi ký, để tiết kiệm dung lượng không cần thiết."
          }
        }
      }
    },
    "Toggling show sheet will present a share sheet after exporting to your files." : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zapnutí sdílícího panelu ho ukáže po exportu do Souborů."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivieren von „Zeige Sheet beim Exportieren“ öffnet ein Share Sheet nach dem Exportieren zu deinen Dateien."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toggling show sheet will present a share sheet after exporting to your files."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengaktifkan tampilan lembar akan menampilkan lembar berbagi setelah mengekspor ke berkas Anda."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Włączenie arkusza spowoduje wyświetlenie arkusza udostępniania po wyeksportowaniu do plików."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paylaşım sayfasını göster seçeneğinin etkinleştirilmesi, dışa aktarım sonrasında bir paylaşım sayfasının görüntülenmesini sağlayacaktır."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bật tính năng này sẽ hiển thị một bảng chia sẻ sau khi xuất IPA vào tệp của bạn."
          }
        }
      }
    },
